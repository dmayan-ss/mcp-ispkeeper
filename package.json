{
  "name": "mcp-ispkeeper",
  "version": "0.1.0",
  "description": "Read-only MCP server for ISPKeeper ISP management software",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-ispkeeper": "dist/index.js"
  },
  "files": ["dist", "manifest.json"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\" --external:node:*",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "bundle": "npm run build && node scripts/bundle.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
